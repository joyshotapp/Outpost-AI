# Environment: development | staging | production
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/factory_insider
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=factory_insider

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (Fallback + Embeddings)
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# HeyGen (Video Multi-language)
HEYGEN_API_KEY=xxxxxxxxxxxxxxxx

# Clay (Data Enrichment)
CLAY_API_KEY=xxxxxxxxxxxxxxxx
CLAY_API_BASE_URL=https://api.clay.com

# Apollo.io (Company Data)
APOLLO_API_KEY=xxxxxxxxxxxxxxxx

# RB2B (Visitor Identification - Personal)
RB2B_API_KEY=xxxxxxxxxxxxxxxx
RB2B_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Leadfeeder (Visitor Identification - Company)
LEADFEEDER_API_TOKEN=xxxxxxxxxxxxxxxx
LEADFEEDER_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# HeyReach (LinkedIn Automation)
HEYREACH_API_KEY=xxxxxxxxxxxxxxxx

# Instantly.ai (Email Outreach)
INSTANTLY_API_KEY=xxxxxxxxxxxxxxxx
INSTANTLY_API_BASE_URL=https://api.instantly.ai

# OpusClip (Video Clipping)
OPUSCLIP_API_KEY=xxxxxxxxxxxxxxxx

# Jasper (Content Generation)
JASPER_API_KEY=xxxxxxxxxxxxxxxx

# Repurpose.io (Content Distribution)
REPURPOSE_API_KEY=xxxxxxxxxxxxxxxx

# Pinecone (Vector Database)
PINECONE_API_KEY=xxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=production
PINECONE_INDEX=factory-insider

# AWS
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=factory-insider-uploads
AWS_S3_BUCKET_REGION=ap-southeast-1

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Slack (Notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX
SLACK_API_TOKEN=xoxb-xxxxxxxxxxxxx
SLACK_CHANNEL_ALERTS=#factory-insider-alerts

# HubSpot (CRM)
HUBSPOT_API_KEY=pat-xxxxxxxxxxxxxxxxxxxxxxx
HUBSPOT_PORTAL_ID=12345678

# Sentry (Error Tracking)
SENTRY_DSN=https://xxxxxxxxxxxxx@xxxxxxxxxxxxx.ingest.sentry.io/xxxxxxxxxxxxx
SENTRY_ENVIRONMENT=development

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Frontend URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BUYER_URL=http://localhost:3000
NEXT_PUBLIC_SUPPLIER_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@factoryinsider.com

# SMTP Fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Feature Flags
FEATURE_OUTBOUND_ENABLED=true
FEATURE_CONTENT_GENERATION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# GDPR / Privacy
GDPR_ENABLED=true
COOKIE_CONSENT_REQUIRED=true
DATA_RETENTION_DAYS=365

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600

# Session
SESSION_DURATION_MINUTES=1440
SESSION_SECURE_COOKIE=false  # Set to true in production

# Timezone
TIMEZONE=Asia/Taipei
