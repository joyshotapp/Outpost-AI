{
  "name": "factory-insider",
  "version": "0.1.0",
  "description": "AI-Powered B2B Manufacturing Marketplace",
  "private": true,
  "workspaces": [
    "frontend",
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^1.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
