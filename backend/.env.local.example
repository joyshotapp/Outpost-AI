# Application Settings
ENVIRONMENT=development
DEBUG=true
APP_NAME=Factory Insider API
APP_VERSION=0.1.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/factory_insider

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Third-party API Keys
ANTHROPIC_API_KEY=your-key-here
HEYGEN_API_KEY=your-key-here
CLAY_API_KEY=your-key-here
APOLLO_API_KEY=your-key-here
PINECONE_API_KEY=your-key-here

# Stripe
STRIPE_SECRET_KEY=your-key-here
STRIPE_WEBHOOK_SECRET=your-key-here

# Slack
SLACK_WEBHOOK_URL=your-webhook-url-here

# AWS
AWS_ACCESS_KEY_ID=your-key-here
AWS_SECRET_ACCESS_KEY=your-key-here
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=factory-insider-dev

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
